<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LinearGradientBrush x:Key="FloatingBarBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F20C5266" Offset="0" />
        <GradientStop Color="#F2147884" Offset="0.56" />
        <GradientStop Color="#F23B617D" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="FloatingBarForegroundBrush" Color="#FFF3FFFF" />
    <SolidColorBrush x:Key="FloatingBarBorderBrush" Color="#B3A6F4F2" />
    <SolidColorBrush x:Key="FloatingBarAccentBrush" Color="#FF73E0D4" />
    <SolidColorBrush x:Key="FloatingBarButtonHoverBrush" Color="#3D73E0D4" />
    <SolidColorBrush x:Key="FloatingBarButtonPressedBrush" Color="#7073E0D4" />
    <SolidColorBrush x:Key="FloatingBarPopupBackgroundBrush" Color="#F20B3D4A" />
    <SolidColorBrush x:Key="FloatingBarPopupInnerBackgroundBrush" Color="#F21C5966" />
    <SolidColorBrush x:Key="FloatingBarPopupInnerBorderBrush" Color="#B373E0D4" />
    <SolidColorBrush x:Key="FloatingBarPopupTitleForegroundBrush" Color="#FFBFFFF8" />
    <SolidColorBrush x:Key="FloatingBarPopupCloseBrush" Color="#FFFF7891" />
    <SolidColorBrush x:Key="FloatingBarPopupHoverBrush" Color="#4473E0D4" />
    <SolidColorBrush x:Key="FloatingBarTitleBackgroundBrush" Color="#CC2B9AA0" />
    <DropShadowEffect x:Key="FloatingBarShadowEffect" BlurRadius="18" ShadowDepth="3" Direction="270" Opacity="0.42" Color="#071C2B" />
    <CornerRadius x:Key="FloatingBarCornerRadius">10</CornerRadius>
</ResourceDictionary>
