<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LinearGradientBrush x:Key="FloatingBarBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F20A0E1A" Offset="0" />
        <GradientStop Color="#F21E3A55" Offset="0.55" />
        <GradientStop Color="#F20F4F58" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="FloatingBarForegroundBrush" Color="#FFE6FFFB" />
    <SolidColorBrush x:Key="FloatingBarBorderBrush" Color="#CC39C5BB" />
    <SolidColorBrush x:Key="FloatingBarAccentBrush" Color="#FF39C5BB" />
    <SolidColorBrush x:Key="FloatingBarButtonHoverBrush" Color="#3D39C5BB" />
    <SolidColorBrush x:Key="FloatingBarButtonPressedBrush" Color="#7039C5BB" />
    <SolidColorBrush x:Key="FloatingBarPopupBackgroundBrush" Color="#F2081018" />
    <SolidColorBrush x:Key="FloatingBarPopupInnerBackgroundBrush" Color="#F2162638" />
    <SolidColorBrush x:Key="FloatingBarPopupInnerBorderBrush" Color="#B339C5BB" />
    <SolidColorBrush x:Key="FloatingBarPopupTitleForegroundBrush" Color="#FFA8E0DC" />
    <SolidColorBrush x:Key="FloatingBarPopupCloseBrush" Color="#FFFF8FB1" />
    <SolidColorBrush x:Key="FloatingBarPopupHoverBrush" Color="#4439C5BB" />
    <SolidColorBrush x:Key="FloatingBarTitleBackgroundBrush" Color="#CC1E6B73" />
    <DropShadowEffect x:Key="FloatingBarShadowEffect" BlurRadius="20" ShadowDepth="3" Direction="270" Opacity="0.55" Color="#000516" />
    <CornerRadius x:Key="FloatingBarCornerRadius">12</CornerRadius>
</ResourceDictionary>